LIVEKIT_URL=<your LiveKit server URL>
LIVEKIT_API_KEY=<your API Key>
LIVEKIT_API_SECRET=<your API Secret>
OPENAI_API_KEY=<your OpenAI API Key>

# Tenant
TENANT_ID=<tenant identifier, e.g. autolife>

# Knowledge Base — AWS S3
KB_S3_BUCKET=<S3 bucket name>
KB_S3_REGION=<AWS region, e.g. eu-west-1>
# KB_S3_KEY=<optional; defaults to kb/${TENANT_ID}/kb.json>
AWS_ACCESS_KEY_ID=<AWS access key>
AWS_SECRET_ACCESS_KEY=<AWS secret key>

# Email (Yandex SMTP — for appointment confirmations)
EMAIL=<sender Yandex email address>
EMAIL_PASS=<Yandex email password>
OFFICE_EMAIL=<destination email for appointment notifications>
